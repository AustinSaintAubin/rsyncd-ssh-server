# Copy this file to .env and adjust the values for your host.
COMPOSE_PROJECT_NAME=rsyncd-server
RSYNCD_HOST_DATA_DIR=/mnt/user/docker/rsyncd-server/data
# RSYNCD_SECRETS_FILE=/mnt/user/docker/rsyncd-server/secrets/rsyncd.secrets
RSYNCD_PORT=873

# Global rsyncd settings.
RSYNCD_UID=root
RSYNCD_GID=root
RSYNCD_ADDRESS=0.0.0.0
RSYNCD_LISTEN_BACKLOG=32
RSYNCD_MAX_CONNECTIONS=4
RSYNCD_TIMEOUT=600
RSYNCD_STRICT_MODES=true
RSYNCD_LOGGING_TRANSFER=true
RSYNCD_LOGGING_FORMAT=%o %h [%a] %m %f %l

# Optional env-only user database. If set, it populates / overwrites the container's rsyncd.secrets file at startup.
RSYNCD_USERS='
readonly_user:replace-with-a-different-password
servers_user:replace-with-a-long-random-password
nas-00_user:replace-with-a-different-password
'

# One variable, single-quoted, spanning multiple lines.
# Do not repeat RSYNCD_MODULES= multiple times.
# Syntax: `MODULE_NAME|MODULE_PATH|AUTH_USERS|READ_ONLY|LIST|USE_CHROOT|COMMENT`
# Relative paths live under /data and may be nested like `foo/bar`.
# Absolute paths start with `/` and are used as-is.
RSYNCD_MODULES='
servers-main|servers|servers_user,readonly_user|false|true|false|Main Servers backup target
nas-00|servers/nas-00|nas-00_user|false|true|false|Synology NAS-00 backup target
readonly_seed|readonly-seed|readonly_user|true|true|false|Read-only seed module
'
