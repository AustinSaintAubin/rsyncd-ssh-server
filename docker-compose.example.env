# Copy this file to .env and adjust the values for your host.
COMPOSE_PROJECT_NAME=rsync-server
RSYNCD_HOST_DATA_DIR=/srv/rsync-backups
RSYNCD_SECRETS_FILE=./secrets/rsyncd.secrets
RSYNCD_PORT=873

# Global rsyncd settings.
RSYNCD_UID=root
RSYNCD_GID=root
RSYNCD_MAX_CONNECTIONS=4
RSYNCD_TIMEOUT=600

# Define RSYNCD_MODULES directly in docker-compose.yaml.
